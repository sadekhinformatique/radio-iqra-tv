  "englishName": "At-Taariq",
  "englishNameTranslation": "The Morning Star",
  "ayahs": [
    {
      "number": 5932,
      "numberInSurah": 1,
      "arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ وَٱلطَّارِقِ",
      "french": "Par le ciel et par l'astre nocturne"
