    },
    {
      "number": 5941,
      "numberInSurah": 10,
      "arabic": "فَمَا لَهُۥ مِن قُوَّةٍۢ وَلَا نَاصِرٍۢ",
      "french": "Il n'aura alors ni force ni secoureur."
    },
    {
      "number": 5942,
      "numberInSurah": 11,
      "arabic": "وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ",
      "french": "Par le ciel qui fait revenir la pluie!"
    },
    {
      "number": 5943,
      "numberInSurah": 12,
      "arabic": "وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ",
      "french": "et par la terre qui se fend!"
    },
    {
      "number": 5944,
      "numberInSurah": 13,
      "arabic": "إِنَّهُۥ لَقَوْلٌۭ فَصْلٌۭ",
