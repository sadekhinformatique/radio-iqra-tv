    },
    {
      "number": 5934,
      "numberInSurah": 3,
      "arabic": "ٱلنَّجْمُ ٱلثَّاقِبُ",
      "french": "C'est l'étoile vivement brillante."
    },
    {
      "number": 5935,
      "numberInSurah": 4,
      "arabic": "إِن كُلُّ نَفْسٍۢ لَّمَّا عَلَيْهَا حَافِظٌۭ",
      "french": "Il n'est pas d'âme qui n'ait sur elle un gardien."
    },
    {
      "number": 5936,
      "numberInSurah": 5,
