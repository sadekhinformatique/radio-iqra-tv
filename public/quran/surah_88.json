  "englishName": "Al-Ghaashiya",
  "englishNameTranslation": "The Overwhelming",
  "ayahs": [
    {
      "number": 5968,
      "numberInSurah": 1,
      "arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَٰشِيَةِ",
      "french": "T'est-il parvenu le récit de l'enveloppante?"
    },
    {
      "number": 5969,
      "numberInSurah": 2,
      "arabic": "وُجُوهٌۭ يَوْمَئِذٍ خَٰشِعَةٌ",
      "french": "Ce jour-là, il y aura des visages humiliés,"
    },
    {
      "number": 5970,
      "numberInSurah": 3,
      "arabic": "عَامِلَةٌۭ نَّاصِبَةٌۭ",
