      "numberInSurah": 9,
      "arabic": "لِّسَعْيِهَا رَاضِيَةٌۭ",
      "french": "contents de leurs efforts,"
    },
    {
      "number": 5977,
      "numberInSurah": 10,
      "arabic": "فِى جَنَّةٍ عَالِيَةٍۢ",
      "french": "dans un haut Jardin,"
    },
    {
