      "numberInSurah": 4,
      "arabic": "تَصْلَىٰ نَارًا حَامِيَةًۭ",
      "french": "Ils brûleront dans un Feu ardent,"
    },
    {
      "number": 5972,
      "numberInSurah": 5,
      "arabic": "تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍۢ",
      "french": "et seront abreuvés d'une source bouillante."
    },
    {
