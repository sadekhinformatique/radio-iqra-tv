{
  "number": 80,
  "name": "سُورَةُ عَبَسَ",
  "englishName": "Abasa",
  "englishNameTranslation": "He frowned",
  "ayahs": [
    {
      "number": 5759,
      "numberInSurah": 1,
      "arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ عَبَسَ وَتَوَلَّىٰٓ",
      "french": "Il s'est renfrogné et il s'est détourné"
    },
    {
      "number": 5760,
      "numberInSurah": 2,
      "arabic": "أَن جَآءَهُ ٱلْأَعْمَىٰ",
      "french": "parce que l'aveugle est venu à lui."
    },
    {
      "number": 5761,
      "numberInSurah": 3,
      "arabic": "وَمَا يُدْرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ",
      "french": "Qui te dit: peut-être [cherche]-t-il à se purifier?"
    },
    {
      "number": 5762,
      "numberInSurah": 4,
      "arabic": "أَوْ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكْرَىٰٓ",
      "french": "ou à se rappeler en sorte que le rappel lui profite?"
    },
    {
      "number": 5763,
      "numberInSurah": 5,
      "arabic": "أَمَّا مَنِ ٱسْتَغْنَىٰ",
      "french": "Quant à celui qui se complaît dans sa suffisance (pour sa richesse)"
    },
    {
      "number": 5764,
      "numberInSurah": 6,
      "arabic": "فَأَنتَ لَهُۥ تَصَدَّىٰ",
      "french": "tu vas avec empressement à sa rencontre."
    },
    {
      "number": 5765,
      "numberInSurah": 7,
      "arabic": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ",
      "french": "Or, que t'importe qu'il ne se purifie pas»."
    },
    {
      "number": 5766,
      "numberInSurah": 8,
      "arabic": "وَأَمَّا مَن جَآءَكَ يَسْعَىٰ",
      "french": "Et quant à celui qui vient à toi avec empressement"
    },
    {
      "number": 5767,
      "numberInSurah": 9,
      "arabic": "وَهُوَ يَخْشَىٰ",
      "french": "tout en ayant la crainte,"
