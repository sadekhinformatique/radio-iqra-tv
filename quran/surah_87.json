{
  "number": 87,
  "name": "سُورَةُ الأَعۡلَىٰ",
  "englishName": "Al-A'laa",
  "englishNameTranslation": "The Most High",
  "ayahs": [
    {
      "number": 5949,
      "numberInSurah": 1,
      "arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ سَبِّحِ ٱسْمَ رَبِّكَ ٱلْأَعْلَى",
      "french": "Glorifie le nom de ton Seigneur, le Très Haut,"
    },
    {
      "number": 5950,
      "numberInSurah": 2,
      "arabic": "ٱلَّذِى خَلَقَ فَسَوَّىٰ",
      "french": "Celui Qui a créé et agencé harmonieusement,"
    },
    {
      "number": 5951,
      "numberInSurah": 3,
      "arabic": "وَٱلَّذِى قَدَّرَ فَهَدَىٰ",
      "french": "qui a décrété et guidé,"
    },
    {
      "number": 5952,
      "numberInSurah": 4,
      "arabic": "وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ",
      "french": "et qui a fait pousser le pâturage,"
    },
    {
      "number": 5953,
      "numberInSurah": 5,
      "arabic": "فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ",
      "french": "et en a fait ensuite un foin sombre."
    },
    {
      "number": 5954,
      "numberInSurah": 6,
      "arabic": "سَنُقْرِئُكَ فَلَا تَنسَىٰٓ",
      "french": "Nous te ferons réciter (le Coran), de sorte que tu n'oublieras"
    },
    {
      "number": 5955,
      "numberInSurah": 7,
      "arabic": "إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ",
      "french": "que ce qu'Allah veut. Car, Il connaît ce qui paraît au grand jour ainsi que ce qui est caché."
    },
    {
      "number": 5956,
      "numberInSurah": 8,
      "arabic": "وَنُيَسِّرُكَ لِلْيُسْرَىٰ",
      "french": "Nous te mettrons sur la voie la plus facile."
    },
    {
      "number": 5957,
      "numberInSurah": 9,
      "arabic": "فَذَكِّرْ إِن نَّفَعَتِ ٱلذِّكْرَىٰ",
      "french": "Rappelle, donc, où le Rappel doit être utile."
    },
    {
      "number": 5958,
      "numberInSurah": 10,
      "arabic": "سَيَذَّكَّرُ مَن يَخْشَىٰ",
      "french": "Quiconque craint (Allah) s'[en] rappellera,"
    },
    {
      "number": 5959,
      "numberInSurah": 11,
      "arabic": "وَيَتَجَنَّبُهَا ٱلْأَشْقَى",
      "french": "et s'en écartera le grand malheureux,"
    },
    {
      "number": 5960,
      "numberInSurah": 12,
      "arabic": "ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ",
      "french": "qui brûlera dans le plus grand Feu,"
    },
    {
      "number": 5961,
      "numberInSurah": 13,
      "arabic": "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ",
      "french": "où il ne mourra ni ne vivra."
    },
    {
      "number": 5962,
      "numberInSurah": 14,
      "arabic": "قَدْ أَفْلَحَ مَن تَزَكَّىٰ",
      "french": "Réussit, certes, celui qui se purifie,"
    },
    {
      "number": 5963,
      "numberInSurah": 15,
      "arabic": "وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ",
      "french": "et se rappelle le nom de son Seigneur, puis célèbre la Salât."
    },
    {
      "number": 5964,
      "numberInSurah": 16,
